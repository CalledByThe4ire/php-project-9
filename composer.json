    "slim/http": "*",
    "slim/psr7": "*",
    "php-di/php-di": "*",
    "guzzlehttp/guzzle": "*",
    "tightenco/collect": "*",
    "slim/php-view": "*",
    "slim/flash": "*",
    "danielstjules/stringy": "*",
    "fakerphp/faker": "*",
    "nesbot/carbon": "^2.64",
    "symfony/string": "^6.2",
    "phpstan/phpstan": "^1.9.2"
  },
  "require-dev": {
    "psy/psysh": "@stable",
    "phpstan/phpstan-phpunit": "^1.2.2",
    "phpstan/extension-installer": "^1.2",
    "symfony/var-dumper": "^6.2.1",
    "phpunit/phpunit": "^9.5.26",
    "squizlabs/php_codesniffer": "^3.7.1"
